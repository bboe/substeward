{
  "private": true,
  "name": "substeward",
  "version": "0.0.0",
  "license": "BSD-2-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "clean": "rm -rf dist",
    "deploy": "npm run test && devvit upload",
    "dev": "devvit playtest",
    "launch": "devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "prettier": "prettier --write .",
    "test": "npm run lint && npm run test:unit && npm run test:harness",
    "test:unit": "npm run type-check && node --test \"dist/types/**/*.test.js\"",
    "test:harness": "vitest run",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.4",
    "@devvit/web": "0.13.4",
    "@hono/node-server": "^1.19.9",
    "devvit": "0.13.4",
    "hono": "4.12.18"
  },
  "devDependencies": {
    "@devvit/test": "^0.13.4",
    "@eslint/js": "9.39.2",
    "@types/node": "^22.19.7",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "9.39.2",
    "prettier": "3.8.1",
    "prettier-plugin-sort-json": "^4.2.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.1",
    "vitest": "^4.1.9"
  }
}
